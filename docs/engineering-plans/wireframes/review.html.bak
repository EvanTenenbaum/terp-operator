<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TERP Operator — Mercury Wireframe Review</title>
  <style>
    /* ═══════════════════════════════════════════════════════════════
       MERCURY INFORMATION ARCHITECTURE — DESIGN TOKENS
       From live demo.mercury.com DOM observation — NOT invented
       ═══════════════════════════════════════════════════════════════ */
    :root {
      /* Typography */
      --font: "Arcadia Text", system-ui, -apple-system, sans-serif;
      --fs-12: 12px; --fs-13: 13px; --fs-14: 14px; --fs-15: 15px;
      --fs-16: 16px; --fs-17: 17px; --fs-19: 19px; --fs-28: 28px;
      --fw-360: 360; --fw-380: 380; --fw-400: 400; --fw-480: 480;

      /* Colors */
      --text: rgb(30, 30, 42);
      --text-secondary: rgb(54, 54, 68);
      --text-muted: rgb(112, 112, 125);
      --text-on-dark: rgb(221, 221, 229);

      /* Cards — NO border, shadow-only */
      --card-bg: #fff;
      --card-radius: 12px;
      --card-shadow: 0 0 2px rgba(175, 178, 206, 0.56), 0 1px 4px rgba(4, 4, 52, 0.1);

      /* Pills — barely visible border */
      --pill-bg: rgb(251, 252, 253);
      --pill-border: 1px solid rgba(112, 115, 147, 0.16);
      --pill-radius: 8px;

      /* Table */
      --row-h: 49px;
      --th-color: rgb(112, 112, 125);

      /* Accent */
      --dark: rgb(30, 30, 42);
      --blue: rgb(70, 91, 209);
      --green: rgb(3, 110, 67);
      --red: rgb(176, 23, 95);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font);
      background: #f5f5f7;
      color: var(--text);
      font-size: var(--fs-15);
      -webkit-font-smoothing: antialiased;
    }

    .page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 24px 120px;
    }

    /* ── Header ── */
    .page > h1 {
      font-size: var(--fs-28); font-weight: var(--fw-480);
      margin-bottom: 8px;
    }
    .page > p {
      font-size: var(--fs-14); color: var(--text-muted);
      margin-bottom: 32px; max-width: 700px; line-height: 1.6;
    }

    /* ── TOC ── */
    .toc {
      display: flex; gap: 10px; flex-wrap: wrap;
      margin-bottom: 40px; padding-bottom: 20px;
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .toc a {
      font-size: var(--fs-13); color: var(--blue); text-decoration: none;
      padding: 4px 8px; border-radius: 6px;
    }
    .toc a:hover { background: rgba(70,91,209,0.06); }

    /* ── Principles banner ── */
    .principles {
      display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px;
    }
    .principles .chip {
      background: var(--pill-bg); border: var(--pill-border);
      border-radius: var(--pill-radius); padding: 6px 14px;
      font-size: var(--fs-13); color: var(--text-secondary);
    }

    /* ═══════════════════════════════════════════════════════════════
       WIREFRAME CARD
       ═══════════════════════════════════════════════════════════════ */
    .wireframe {
      background: var(--card-bg); border-radius: var(--card-radius);
      padding: 24px; box-shadow: var(--card-shadow); margin-bottom: 32px;
      scroll-margin-top: 24px;
    }
    .wireframe h2 {
      font-size: var(--fs-17); font-weight: var(--fw-480);
      color: var(--text); margin-bottom: 4px;
    }
    .wireframe .principle {
      font-size: var(--fs-13); color: var(--text-muted);
      margin-bottom: 16px; font-style: italic;
    }

    /* ── Diagram container ── */
    .diagram {
      background: #fafafa; border-radius: 10px; padding: 20px;
      font-size: var(--fs-13); overflow-x: auto;
    }

    /* ═══════════════════════════════════════════════════════════════
       DIAGRAM BUILDING BLOCKS — Mercury-styled
       ═══════════════════════════════════════════════════════════════ */
    .wf-row { display: flex; gap: 8px; }
    .wf-col { display: flex; flex-direction: column; }

    /* Sidebar */
    .wf-sidebar {
      width: 200px; flex-shrink: 0; min-height: 280px;
      background: var(--dark); color: var(--text-on-dark);
      border-radius: 10px; padding: 16px 12px; font-size: var(--fs-13);
      display: flex; flex-direction: column; gap: 8px;
    }
    .wf-sidebar .brand { font-size: var(--fs-16); font-weight: var(--fw-480); margin-bottom: 4px; }
    .wf-sidebar .nav-item { padding: 6px 8px; border-radius: 6px; color: var(--text-on-dark); }
    .wf-sidebar .nav-item.active { background: rgba(255,255,255,0.10); font-weight: var(--fw-480); }
    .wf-sidebar .nav-item.dim { color: rgba(221,221,229,0.5); }
    .wf-sidebar .section-label {
      font-size: var(--fs-12); color: rgba(221,221,229,0.35);
      text-transform: uppercase; letter-spacing: 0.5px; padding: 12px 8px 4px;
    }
    .wf-sidebar .bookmark { color: rgba(221,221,229,0.6); font-size: var(--fs-12); padding: 2px 8px; }

    /* Main content area */
    .wf-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 10px; }

    /* Topbar-style header row */
    .wf-topbar {
      display: flex; justify-content: space-between; align-items: center;
      background: var(--dark); color: var(--text-on-dark);
      border-radius: 10px; padding: 8px 20px; font-size: var(--fs-13);
    }

    /* Filter pills row */
    .wf-pills { display: flex; gap: 6px; flex-wrap: wrap; }
    .wf-pill {
      background: var(--pill-bg); border: var(--pill-border);
      border-radius: var(--pill-radius); padding: 5px 12px;
      font-size: var(--fs-14); color: var(--text);
      display: inline-flex; align-items: center; gap: 4px;
      white-space: nowrap;
    }
    .wf-pill.sm { font-size: var(--fs-13); padding: 4px 10px; }
    .wf-pill.active { background: rgba(70,91,209,0.06); border-color: rgba(70,91,209,0.25); color: var(--blue); }

    /* KPI line */
    .wf-kpi-line {
      font-size: var(--fs-13); color: var(--text-secondary);
      padding: 4px 0; white-space: nowrap;
    }
    .wf-kpi-line b { font-weight: var(--fw-480); color: var(--text); }

    /* Welcome header */
    .wf-welcome { font-size: var(--fs-19); font-weight: var(--fw-480); color: var(--text); }

    /* Quick actions */
    .wf-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .wf-btn {
      background: var(--pill-bg); border: var(--pill-border);
      border-radius: var(--pill-radius); padding: 6px 16px;
      font-size: var(--fs-14); color: var(--text); font-family: var(--font);
      display: inline-flex; align-items: center; gap: 4px; white-space: nowrap;
    }
    .wf-btn.primary { background: var(--dark); color: #fff; border: none; }
    .wf-btn.blue { background: var(--blue); color: #fff; border: none; }
    .wf-btn.dark { background: var(--dark); color: #fff; border: none; }

    /* Cards */
    .wf-card {
      background: var(--card-bg); border-radius: 10px;
      padding: 20px 24px; box-shadow: var(--card-shadow);
    }
    .wf-big-number { font-size: 28px; font-weight: var(--fw-380); color: var(--text); }
    .wf-label { font-size: 12px; color: var(--text-muted); }

    /* Table */
    .wf-table { border-radius: 8px; overflow: hidden; }
    .wf-table-inner { width: 100%; }
    .wf-th {
      font-size: 12px; color: var(--th-color); font-weight: var(--fw-400);
      border-bottom: 1px solid rgba(0,0,0,0.06); padding: 8px 16px;
    }
    .wf-td {
      font-size: var(--fs-15); color: var(--text);
      height: var(--row-h); padding: 0 16px;
      border-bottom: 1px solid rgba(0,0,0,0.04);
    }

    /* Checkbox */
    .wf-cb {
      width: 16px; height: 16px; border: 2px solid #d0d0d5;
      border-radius: 3px; flex-shrink: 0;
    }
    .wf-cb.checked { background: var(--dark); border-color: var(--dark); }
    .wf-cb.checked::after { content: ""; }

    /* Tags */
    .wf-tag {
      display: inline-block; padding: 2px 8px; border-radius: 4px;
      font-size: 12px; font-weight: var(--fw-400);
    }
    .wf-tag.blue { background: rgba(70,91,209,0.08); color: var(--blue); }
    .wf-tag.green { background: rgba(3,110,67,0.08); color: var(--green); }
    .wf-tag.red { background: rgba(176,23,95,0.06); color: var(--red); }
    .wf-tag.gray { background: rgba(112,112,125,0.08); color: var(--text-muted); }

    /* Bulk action bar */
    .wf-bulkbar {
      background: var(--dark); color: var(--text-on-dark);
      border-radius: 8px; padding: 10px 16px;
      display: flex; gap: 16px; align-items: center; font-size: var(--fs-13);
    }
    .wf-bulkbar .wf-btn { background: rgba(255,255,255,0.12); border: none; color: #fff; }

    /* Slideover */
    .wf-so {
      width: 300px; flex-shrink: 0; border-left: 1px solid rgba(0,0,0,0.06);
      background: #fff; border-radius: 0 10px 10px 0; padding: 20px 16px;
      display: flex; flex-direction: column; gap: 12px;
    }
    .wf-so h3 { font-size: var(--fs-17); font-weight: var(--fw-480); }
    .wf-so .close { font-size: var(--fs-16); color: var(--text-muted); cursor: pointer; }

    /* Popover */
    .wf-pop {
      background: #fff; border-radius: 10px;
      box-shadow: 0 4px 20px rgba(4,4,52,0.14), 0 1px 6px rgba(4,4,52,0.06);
      padding: 14px; min-width: 280px;
    }
    .wf-pop .search-bar {
      width: 100%; padding: 6px 12px; border: var(--pill-border);
      border-radius: var(--pill-radius); font-size: var(--fs-13);
      font-family: var(--font); margin-bottom: 8px;
    }
    .wf-pop .opt { padding: 6px 8px; font-size: var(--fs-14); display: flex; gap: 8px; align-items: center; }
    .wf-pop .pop-footer { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }

    /* Combobox inline */
    .wf-cbox { position: relative; display: inline-block; }
    .wf-cbox-val {
      padding: 2px 16px 2px 8px; border: 1px solid transparent;
      border-radius: 6px; font-size: var(--fs-15); color: var(--text);
      cursor: pointer;
    }
    .wf-cbox-val:hover { background: rgba(0,0,0,0.03); border-color: rgba(0,0,0,0.08); }
    .wf-cbox-val.open { border-color: var(--blue); background: #fff; }
    .wf-cbox-dd {
      position: absolute; top: 100%; left: 0; z-index: 5;
      min-width: 140px; background: #fff; border-radius: 8px;
      box-shadow: 0 4px 16px rgba(4,4,52,0.12); overflow: hidden; margin-top: 2px;
    }
    .wf-cbox-dd .citem { padding: 8px 14px; font-size: var(--fs-15); cursor: pointer; }
    .wf-cbox-dd .citem:hover, .wf-cbox-dd .citem.sel { background: rgba(70,91,209,0.06); }

    /* Saving states */
    .wf-saving { color: var(--text-muted); font-size: var(--fs-13); display: flex; align-items: center; gap: 4px; }
    .wf-saved { color: var(--green); font-size: var(--fs-13); display: flex; align-items: center; gap: 4px; }

    /* Expand / master-detail */
    .wf-expand { cursor: pointer; color: var(--text-muted); width: 20px; font-size: 14px; }
    .wf-child-row { padding-left: 32px; background: rgba(0,0,0,0.01); height: 36px; }

    /* Profile page */
    .wf-back { font-size: var(--fs-14); color: var(--blue); margin-bottom: 16px; }
    .wf-avatar { width: 48px; height: 48px; border-radius: 50%; background: rgba(70,91,209,0.15); }
    .wf-tabs { display: flex; gap: 6px; margin: 16px 0; }
    .wf-tab {
      padding: 6px 16px; border-radius: 6px; font-size: var(--fs-14);
      color: var(--text-secondary); cursor: pointer;
    }
    .wf-tab.active { background: rgba(70,91,209,0.06); color: var(--blue); }

    /* Error states */
    .wf-err-cell {
      border-left: 3px solid var(--red); padding: 4px 12px;
      display: flex; align-items: center; gap: 8px; color: var(--red); font-size: var(--fs-13);
    }
    .wf-empty {
      text-align: center; padding: 40px 20px; color: var(--text-muted);
      display: flex; flex-direction: column; align-items: center; gap: 12px;
    }
    .wf-empty p { font-size: var(--fs-15); }
    .wf-empty .wf-btn { margin-top: 4px; }

    /* Form fields in slideover */
    .wf-field { margin-bottom: 10px; }
    .wf-field label { display: block; font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
    .wf-field input, .wf-field select {
      width: 100%; padding: 7px 12px; border: var(--pill-border);
      border-radius: var(--pill-radius); font-size: var(--fs-14);
      font-family: var(--font); background: #fff;
    }

    /* Specs table */
    .specs { margin-top: 20px; }
    .specs table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .specs th {
      text-align: left; color: var(--text-muted); font-weight: var(--fw-400);
      padding: 4px 12px; border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .specs td { padding: 4px 12px; border-bottom: 1px solid rgba(0,0,0,0.03); }
    .specs td:first-child { font-weight: var(--fw-480); white-space: nowrap; }

    /* Utility */
    .gap-8 { gap: 8px; }
    .gap-12 { gap: 12px; }
    .gap-16 { gap: 16px; }
    .mt-12 { margin-top: 12px; }
    .mt-16 { margin-top: 16px; }
    .mb-12 { margin-bottom: 12px; }
    .mb-16 { margin-bottom: 16px; }
    .ws-nw { white-space: nowrap; }
    .fg-1 { flex: 1; }
    [data-wf-id] { transition: box-shadow 0.15s ease; }
    [data-wf-id]:hover { box-shadow: inset 0 0 0 1px var(--blue); }
  </style>
</head>
<body>
  <div class="page">

    <!-- ── HEADER ── -->
    <h1>TERP Operator — Mercury IA Wireframe Review</h1>
    <p>
      Ten information-architecture patterns derived from observing the live <strong>demo.mercury.com</strong> DOM.
      Every Mercury view has ONE job. Chrome is invisible. The table IS the view.
      Bulk actions, slideovers, and filters use progressive disclosure — they only appear
      when invoked. No tab bars, no summary strips, no view headers.
    </p>

    <!-- ── PRINCIPLES ── -->
    <div class="principles">
      <span class="chip">1 view = 1 job</span>
      <span class="chip">Show less; click for more</span>
      <span class="chip">Info distributed contextually</span>
      <span class="chip">Chrome is invisible</span>
      <span class="chip">One primary metric</span>
      <span class="chip">The table IS the view</span>
    </div>

    <!-- ── TOC ── -->
    <nav class="toc">
      <a href="#wf-dashboard">1. Dashboard</a>
      <a href="#wf-gridview">2. Grid View</a>
      <a href="#wf-selected">3. Selection · Bulk Bar</a>
      <a href="#wf-slideover">4. Detail Slideover</a>
      <a href="#wf-filter">5. Filter Popover</a>
      <a href="#wf-combobox">6. Inline Combobox</a>
      <a href="#wf-create">7. Create Slideover</a>
      <a href="#wf-masterdetail">8. Master-Detail</a>
      <a href="#wf-profile">9. Full-Page Detail</a>
      <a href="#wf-errors">10. Error Recovery</a>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════════
         1. DASHBOARD
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-dashboard">
      <h2>1. Dashboard</h2>
      <p class="principle">Job: Show financial overview at a glance. NOT a multi-section cockpit.</p>

      <div class="diagram">
        <div class="wf-row">
          <!-- Sidebar -->
          <div class="wf-sidebar" data-wf-id="wf-dashboard-sidebar">
            <div class="brand">Mercury Demo Pro</div>
            <div class="nav-item active" data-wf-id="wf-dashboard-nav-home">Home</div>
            <div class="nav-item" data-wf-id="wf-dashboard-nav-tasks">Tasks <span class="dim">10</span></div>
            <div class="nav-item dim" data-wf-id="wf-dashboard-nav-accounts">Accounts</div>
            <div class="nav-item dim" data-wf-id="wf-dashboard-nav-transactions">Transactions</div>
            <div class="nav-item dim" data-wf-id="wf-dashboard-nav-cards">Cards</div>
            <div class="nav-item dim" data-wf-id="wf-dashboard-nav-payments">Payments</div>
            <div class="nav-item dim" data-wf-id="wf-dashboard-nav-invoicing">Invoicing</div>
            <div class="section-label">Bookmarks</div>
            <div class="bookmark" data-wf-id="wf-dashboard-bm-ops">Ops / Payroll &nbsp; $2,023,267.12</div>
            <div class="bookmark" data-wf-id="wf-dashboard-bm-cc">Credit Card &nbsp; $48,502.31</div>
          </div>

          <!-- Main -->
          <div class="wf-main">
            <div class="wf-welcome" data-wf-id="wf-dashboard-welcome">Welcome, Jane</div>

            <div class="wf-actions" data-wf-id="wf-dashboard-quick-actions">
              <span class="wf-btn primary" data-wf-id="wf-dashboard-btn-send">Send</span>
              <span class="wf-btn" data-wf-id="wf-dashboard-btn-transfer">Transfer</span>
              <span class="wf-btn" data-wf-id="wf-dashboard-btn-deposit">Deposit</span>
              <span class="wf-btn" data-wf-id="wf-dashboard-btn-request">Request</span>
              <span class="wf-btn" data-wf-id="wf-dashboard-btn-upload">Upload bill</span>
            </div>

            <!-- ONE primary card -->
            <div class="wf-card" data-wf-id="wf-dashboard-balance-card">
              <div class="wf-label">Mercury balance</div>
              <div class="wf-big-number" data-wf-id="wf-dashboard-balance-amount">$5,216,471.18</div>
              <div class="wf-actions mt-12" data-wf-id="wf-dashboard-balance-toggles">
                <span class="wf-pill sm active">Graph</span>
                <span class="wf-pill sm">Table</span>
              </div>
              <div style="height:80px;background:rgba(70,91,209,0.04);border-radius:8px;margin-top:12px;display:flex;align-items:center;justify-content:center;" data-wf-id="wf-dashboard-chart-area">
                <span style="color:var(--text-muted);font-size:12px;">Chart area</span>
              </div>
            </div>

            <!-- Activity table with tab pills -->
            <div class="wf-label mb-12" data-wf-id="wf-dashboard-activity-header">Recent activity</div>
            <div class="wf-pills mb-12" data-wf-id="wf-dashboard-activity-tabs">
              <span class="wf-pill sm active">Recent</span>
              <span class="wf-pill sm">My transactions</span>
              <span class="wf-pill sm">Monthly money in</span>
              <span class="wf-pill sm">Monthly money out</span>
              <span class="wf-pill sm">Operating expenses</span>
            </div>
            <div class="wf-table">
              <table class="wf-table-inner">
                <tr><th class="wf-th">Date</th><th class="wf-th">To / From</th><th class="wf-th">Amount</th></tr>
                <tr data-wf-id="wf-dashboard-txn-row-1"><td class="wf-td">Jun 15</td><td class="wf-td">Acme Corporation</td><td class="wf-td">$12,400.00</td></tr>
                <tr data-wf-id="wf-dashboard-txn-row-2"><td class="wf-td">Jun 14</td><td class="wf-td">Beta Industries</td><td class="wf-td">$8,200.00</td></tr>
                <tr data-wf-id="wf-dashboard-txn-row-3"><td class="wf-td">Jun 13</td><td class="wf-td">Gamma Ltd</td><td class="wf-td">$4,150.00</td></tr>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>WHAT</th><th>DOESN'T EXIST ON THIS PAGE</th></tr>
          <tr><td>KPI grid</td><td>❌ One primary metric only. No 4-up KPI cards.</td></tr>
          <tr><td>Tab bar above table</td><td>❌ Status tabs live in sidebar nav or filter pills, not above the table.</td></tr>
          <tr><td>Summary strip</td><td>❌ No separate component. Balance information lives in sidebar bookmarks.</td></tr>
          <tr><td>Multiple sections</td><td>❌ One balance card + activity table. That's it.</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         2. GRID VIEW (PURCHASE ORDERS)
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-gridview">
      <h2>2. Grid View — Purchase Orders</h2>
      <p class="principle">Job: Show purchase orders. That's it. No tab bar. No view header. No bulk bar. No slideover.</p>

      <div class="diagram">
        <div class="wf-row">
          <!-- Sidebar (compressed) -->
          <div class="wf-sidebar" data-wf-id="wf-grid-sidebar">
            <div class="brand">TERP Operator</div>
            <div class="nav-item" data-wf-id="wf-grid-nav-home">Home</div>
            <div class="nav-item dim" data-wf-id="wf-grid-nav-purchases">Purchases</div>
            <div class="nav-item active" data-wf-id="wf-grid-nav-pos">Purchase Orders</div>
            <div class="nav-item dim" data-wf-id="wf-grid-nav-receiving">Receiving</div>
            <div class="nav-item dim" data-wf-id="wf-grid-nav-sales">Sales</div>
            <div class="nav-item dim" data-wf-id="wf-grid-nav-inventory">Inventory</div>
            <div class="section-label">Status</div>
            <div class="nav-item" data-wf-id="wf-grid-nav-all">All POs</div>
            <div class="nav-item" data-wf-id="wf-grid-nav-draft">Draft <span class="dim">4</span></div>
            <div class="nav-item" data-wf-id="wf-grid-nav-ordered">Ordered <span class="dim">3</span></div>
            <div class="nav-item" data-wf-id="wf-grid-nav-posted">Posted <span class="dim">5</span></div>
            <div class="nav-item" data-wf-id="wf-grid-nav-received">Received <span class="dim">3</span></div>
          </div>

          <!-- Main: Just pills, KPI line, table -->
          <div class="wf-main">
            <!-- Filter pills only -->
            <div class="wf-pills" data-wf-id="wf-grid-filter-pills">
              <span class="wf-pill" data-wf-id="wf-grid-pill-all">All POs ▾</span>
              <span class="wf-pill" data-wf-id="wf-grid-pill-date">Date ▾</span>
