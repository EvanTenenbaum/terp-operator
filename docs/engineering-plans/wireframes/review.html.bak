              <span class="wf-pill">All POs ▾</span>
              <span class="wf-pill">Date ▾</span>
            </div>
            <div class="wf-kpi-line"><b>15 POs</b> · $124,500</div>

            <!-- Compressed table + slideover -->
            <div class="wf-row">
              <div class="wf-table fg-1">
                <table class="wf-table-inner">
                  <tr><th class="wf-th"></th><th class="wf-th">Vendor</th><th class="wf-th">Total</th></tr>
                  <tr data-wf-id="wf-so-row-1"><td class="wf-td"><span class="wf-cb"></span></td><td class="wf-td">Acme Corp</td><td class="wf-td">$12,400</td></tr>
                  <tr data-wf-id="wf-so-row-2" style="background:rgba(70,91,209,0.04);"><td class="wf-td"><span class="wf-cb"></span></td><td class="wf-td">Beta Industries</td><td class="wf-td">$8,200</td></tr>
                  <tr data-wf-id="wf-so-row-3"><td class="wf-td"><span class="wf-cb"></span></td><td class="wf-td">Gamma Ltd</td><td class="wf-td">$4,150</td></tr>
                </table>
              </div>

              <!-- Slideover -->
              <div class="wf-so" data-wf-id="wf-so-slideover">
                <div style="display:flex;justify-content:space-between;align-items:center;" data-wf-id="wf-so-header">
                  <span>PO #1042</span>
                  <span class="close" data-wf-id="wf-so-close">✕</span>
                </div>
                <div data-wf-id="wf-so-body">
                  <div style="font-size:14px;color:var(--text-secondary);margin-bottom:4px;">Acme Corp</div>
                  <div class="wf-big-number" style="font-size:20px;margin-bottom:12px;">$12,400 <span class="wf-tag blue">Draft</span></div>

                  <div class="wf-pills mb-12">
                    <span class="wf-pill sm active">Lines</span>
                    <span class="wf-pill sm">History</span>
                  </div>

                  <div style="border-top:1px solid rgba(0,0,0,0.06);padding-top:10px;">
                    <div style="display:flex;justify-content:space-between;font-size:13px;padding:4px 0;">
                      <span>Roma Tomatoes</span><span>50 cs</span><span>$4,800</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:13px;padding:4px 0;">
                      <span>Green Peppers</span><span>30 cs</span><span>$3,200</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;font-size:13px;padding:4px 0;">
                      <span>Red Onions</span><span>40 cs</span><span>$4,400</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>TRIGGER</th><th>BEHAVIOR</th></tr>
          <tr><td>Click row</td><td>Slideover opens from right. Table compresses. Highlighted row stays highlighted.</td></tr>
          <tr><td>Click ✕ / Escape</td><td>Slideover closes. Table returns to full width.</td></tr>
          <tr><td>Click different row</td><td>Slideover content updates. No animation flash.</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         5. FILTER POPOVER
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-filter">
      <h2>5. Filter Popover</h2>
      <p class="principle">Job: Filter the table. Appears from the filter pill on click. Dismisses on click-outside or Escape.</p>

      <div class="diagram">
        <div class="wf-row">
          <div class="wf-sidebar" data-wf-id="wf-filter-sidebar">
            <div class="brand">TERP Operator</div>
            <div class="nav-item active">Purchase Orders</div>
            <div class="nav-item dim">Sales</div>
          </div>
          <div class="wf-main">
            <!-- Filter pills with one open -->
            <div style="position:relative;" class="mb-16">
              <div class="wf-pills">
                <span class="wf-pill">All POs ▾</span>
                <span class="wf-pill">Date ▾</span>
                <span class="wf-pill active" data-wf-id="wf-filter-pill-vendor">Vendor ▲</span>
                <span class="wf-pill">Status ▾</span>
              </div>
              <!-- Popover positioned below the Vendor pill -->
              <div class="wf-pop" style="position:absolute;top:36px;left:170px;z-index:5;" data-wf-id="wf-filter-popover">
                <input class="search-bar" placeholder="Search vendors..." data-wf-id="wf-filter-search">
                <div class="opt" data-wf-id="wf-filter-opt-acme">
                  <span class="wf-cb checked"></span> Acme Corporation
                </div>
                <div class="opt" data-wf-id="wf-filter-opt-beta">
                  <span class="wf-cb"></span> Beta Industries
                </div>
                <div class="opt" data-wf-id="wf-filter-opt-gamma">
                  <span class="wf-cb"></span> Gamma Ltd
                </div>
                <div class="opt" data-wf-id="wf-filter-opt-delta">
                  <span class="wf-cb"></span> Delta Supply Co
                </div>
                <div class="pop-footer">
                  <span class="wf-btn sm" data-wf-id="wf-filter-clear">Clear</span>
                  <span class="wf-btn sm primary" data-wf-id="wf-filter-apply">Apply</span>
                </div>
              </div>
            </div>

            <div class="wf-kpi-line"><b>15 POs</b> · $124,500</div>
            <div class="wf-table">
              <table class="wf-table-inner">
                <tr><th class="wf-th"></th><th class="wf-th">Vendor</th><th class="wf-th">Status</th><th class="wf-th">Total</th></tr>
                <tr data-wf-id="wf-filter-row-1"><td class="wf-td"><span class="wf-cb"></span></td><td class="wf-td">Acme Corp</td><td class="wf-td"><span class="wf-tag blue">Draft</span></td><td class="wf-td">$12,400</td></tr>
                <tr data-wf-id="wf-filter-row-2"><td class="wf-td"><span class="wf-cb"></span></td><td class="wf-td">Beta Inc</td><td class="wf-td"><span class="wf-tag green">Posted</span></td><td class="wf-td">$8,200</td></tr>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>STATE</th><th>BEHAVIOR</th></tr>
          <tr><td>Closed</td><td>Only the pill is visible. Down-pointing chevron ▾</td></tr>
          <tr><td>Open</td><td>Popover appears below pill. Up-pointing chevron ▲ Pill gets active highlight.</td></tr>
          <tr><td>Dismiss</td><td>Click outside, press Escape, or click the pill again.</td></tr>
          <tr><td>Applied</td><td>Popover closes. Active filter count shown in pill (e.g. "Vendor (2)").</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         6. INLINE EDIT — COMBOBOX
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-combobox">
      <h2>6. Inline Edit — Combobox in Cell</h2>
      <p class="principle">Job: Edit a single cell value. 4 states: Closed, Open, Saving, Saved.</p>

      <div class="diagram">
        <div class="wf-row gap-16">
          <!-- State 1: Closed -->
          <div style="flex:1;" class="wf-card">
            <div class="wf-label mb-12">1. Closed</div>
            <div class="wf-cbox" data-wf-id="wf-cb-state-closed">
              <span class="wf-cbox-val">Draft&ensp;▾</span>
            </div>
          </div>

          <!-- State 2: Open -->
          <div style="flex:1;" class="wf-card">
            <div class="wf-label mb-12">2. Open (clicked)</div>
            <div class="wf-cbox" data-wf-id="wf-cb-state-open">
              <span class="wf-cbox-val open">Draft&ensp;▴</span>
              <div class="wf-cbox-dd">
                <div class="citem sel" data-wf-id="wf-cb-opt-draft">Draft</div>
                <div class="citem" data-wf-id="wf-cb-opt-confirmed">Confirmed</div>
                <div class="citem" data-wf-id="wf-cb-opt-posted">Posted</div>
                <div class="citem" data-wf-id="wf-cb-opt-cancelled">Cancelled</div>
              </div>
            </div>
          </div>

          <!-- State 3: Saving -->
          <div style="flex:1;" class="wf-card">
            <div class="wf-label mb-12">3. Saving</div>
            <div class="wf-saving" data-wf-id="wf-cb-state-saving">
              <span style="display:inline-block;width:12px;height:12px;border:2px solid var(--text-muted);border-top-color:transparent;border-radius:50%;animation:spin 0.6s linear infinite;"></span>
              Saving...
            </div>
            <style>.spinner{width:12px;height:12px;border:2px solid var(--text-muted);border-top-color:transparent;border-radius:50%;display:inline-block;}</style>
          </div>

          <!-- State 4: Saved -->
          <div style="flex:1;" class="wf-card">
            <div class="wf-label mb-12">4. Saved</div>
            <div class="wf-saved" data-wf-id="wf-cb-state-saved">
              <span>Confirmed ✓</span>
            </div>
            <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">(green check, then fades)</div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>STATE</th><th>TRIGGER</th><th>VISUAL</th></tr>
          <tr><td>Closed</td><td>Default</td><td>Value + ▾. Border: transparent (appears on hover).</td></tr>
          <tr><td>Open</td><td>Click cell</td><td>Dropdown below. ▾ → ▴. Blue border.</td></tr>
          <tr><td>Saving</td><td>Click option</td><td>Dropdown closes. Spinner + "Saving..."</td></tr>
          <tr><td>Saved</td><td>Server responds</td><td>"Confirmed ✓" in green. Fades to normal after 1s.</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         7. AUTHORING — CREATE PO
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-create">
      <h2>7. Authoring — Create Purchase Order</h2>
      <p class="principle">Job: Create a new PO. Slideover form. Table stays visible behind. No full-page takeover.</p>

      <div class="diagram">
        <div class="wf-row">
          <div class="wf-sidebar" data-wf-id="wf-create-sidebar">
            <div class="brand">TERP Operator</div>
            <div class="nav-item active">Purchase Orders</div>
            <div class="nav-item dim">Sales</div>
          </div>
          <div class="wf-main">
            <div class="wf-pills">
              <span class="wf-pill">All POs ▾</span>
              <span class="wf-pill">Date ▾</span>
              <span class="wf-pill">+ New PO</span>
            </div>
            <div class="wf-kpi-line"><b>15 POs</b> · $124,500</div>

            <div class="wf-row">
              <!-- Compressed table -->
              <div class="wf-table fg-1">
                <table class="wf-table-inner">
                  <tr><th class="wf-th">Vendor</th><th class="wf-th">Status</th><th class="wf-th">Total</th></tr>
                  <tr data-wf-id="wf-create-tbl-row-1"><td class="wf-td">Acme Corp</td><td class="wf-td"><span class="wf-tag blue">Draft</span></td><td class="wf-td">$12,400</td></tr>
                  <tr data-wf-id="wf-create-tbl-row-2"><td class="wf-td">Beta Inc</td><td class="wf-td"><span class="wf-tag green">Posted</span></td><td class="wf-td">$8,200</td></tr>
                  <tr data-wf-id="wf-create-tbl-row-3"><td class="wf-td">Gamma Ltd</td><td class="wf-td"><span class="wf-tag green">Confirmed</span></td><td class="wf-td">$4,150</td></tr>
                </table>
              </div>

              <!-- Create slideover -->
              <div class="wf-so" data-wf-id="wf-create-slideover">
                <div style="display:flex;justify-content:space-between;align-items:center;" data-wf-id="wf-create-so-header">
                  <span>New PO</span>
                  <span class="close" data-wf-id="wf-create-so-close">✕</span>
                </div>

                <div class="wf-field" data-wf-id="wf-create-field-vendor">
                  <label>Vendor</label>
                  <select><option>Select vendor...</option><option>Acme Corporation</option><option>Beta Industries</option></select>
                </div>
                <div class="wf-field" data-wf-id="wf-create-field-date">
                  <label>Date</label>
                  <input type="text" placeholder="📅 Select date...">
                </div>
                <div class="wf-field" data-wf-id="wf-create-field-terms">
                  <label>Terms</label>
                  <select><option>Net 30</option><option>Net 15</option><option>Due on receipt</option></select>
                </div>

                <div class="wf-label mt-12" style="margin-bottom:4px;">Lines</div>
                <div style="font-size:12px;color:var(--text-muted);padding:8px 0;text-align:center;border:1px dashed rgba(0,0,0,0.1);border-radius:6px;" data-wf-id="wf-create-add-line">+ Add Line</div>

                <div class="mt-16">
                  <span class="wf-btn primary" data-wf-id="wf-create-save-draft">Save Draft</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>WHAT</th><th>BEHAVIOR</th></tr>
          <tr><td>Open</td><td>Click "+ New PO" pill or sidebar action. Slideover opens from right.</td></tr>
          <tr><td>Form</td><td>Vendor, Date, Terms + dynamic line items.</td></tr>
          <tr><td>Save</td><td>"Save Draft" creates PO. Row appears in background table immediately.</td></tr>
          <tr><td>Close</td><td>✕ or Escape. If form is dirty, confirm before closing (undo: form clears).</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         8. MASTER-DETAIL — EXPANDABLE ROWS
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-masterdetail">
      <h2>8. Master-Detail — Expandable Rows</h2>
      <p class="principle">Job: Show child items (batches/lines) inside expanded rows. No extra chrome.</p>

      <div class="diagram">
        <div class="wf-row">
          <div class="wf-sidebar" data-wf-id="wf-md-sidebar">
            <div class="brand">TERP Operator</div>
            <div class="nav-item active">Receiving</div>
            <div class="nav-item dim">Intake</div>
          </div>
          <div class="wf-main">
            <div class="wf-pills">
              <span class="wf-pill active">Ready ▾</span>
              <span class="wf-pill">Date ▾</span>
            </div>
            <div class="wf-kpi-line"><b>8 POs pending</b> · 142 batches</div>

            <div class="wf-table">
              <table class="wf-table-inner">
                <tr><th class="wf-th" style="width:28px;"></th><th class="wf-th">PO</th><th class="wf-th">Vendor</th><th class="wf-th">Status</th></tr>
                <tr data-wf-id="wf-md-row-collapsed">
                  <td class="wf-td" style="color:var(--text-muted);">▸</td>
                  <td class="wf-td">PO #1004</td>
                  <td class="wf-td">Acme Corp</td>
                  <td class="wf-td"><span class="wf-tag green">Received</span></td>
                </tr>
                <tr data-wf-id="wf-md-row-expanded-header">
                  <td class="wf-td" style="color:var(--text-muted);">▾</td>
                  <td class="wf-td">PO #1005</td>
                  <td class="wf-td">Beta Industries</td>
                  <td class="wf-td"><span class="wf-tag green">Received</span></td>
                </tr>
                <!-- Child rows -->
                <tr data-wf-id="wf-md-child-1">
                  <td class="wf-td" style="height:34px;"></td>
                  <td class="wf-td" style="height:34px;padding-left:32px;font-size:13px;color:var(--text-secondary);">
                    Batch A-1 &nbsp; Roma Tomato &nbsp;
                    <span style="color:var(--green);">✓</span>
                  </td>
                  <td class="wf-td" style="height:34px;"></td>
                  <td class="wf-td" style="height:34px;"></td>
                </tr>
                <tr data-wf-id="wf-md-child-2">
                  <td class="wf-td" style="height:34px;"></td>
                  <td class="wf-td" style="height:34px;padding-left:32px;font-size:13px;color:var(--text-secondary);">
                    Batch A-2 &nbsp; Green Pepper &nbsp;
                    <span style="color:var(--green);">✓</span>
                  </td>
                  <td class="wf-td" style="height:34px;"></td>
                  <td class="wf-td" style="height:34px;"></td>
                </tr>
                <tr data-wf-id="wf-md-child-3">
                  <td class="wf-td" style="height:34px;"></td>
                  <td class="wf-td" style="height:34px;padding-left:32px;font-size:13px;color:var(--text-secondary);">
                    Batch A-3 &nbsp; Red Onion &nbsp;
                    <span style="color:var(--text-muted);">⏳</span>
                  </td>
                  <td class="wf-td" style="height:34px;"></td>
                  <td class="wf-td" style="height:34px;"></td>
                </tr>
                <tr data-wf-id="wf-md-row-collapsed-2">
                  <td class="wf-td" style="color:var(--text-muted);">▸</td>
                  <td class="wf-td">PO #1006</td>
                  <td class="wf-td">Gamma Ltd</td>
                  <td class="wf-td"><span class="wf-tag blue">Received</span></td>
                </tr>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>TRIGGER</th><th>BEHAVIOR</th></tr>
          <tr><td>Click ▸</td><td>Row expands. ▸ → ▾. Child rows appear below.</td></tr>
          <tr><td>Click ▾</td><td>Row collapses. ▾ → ▸. Child rows disappear.</td></tr>
          <tr><td>Child rows</td><td>No extra chrome. No border changes. Just indented text with status icons.</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         9. FULL-PAGE DETAIL / PROFILE
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-profile">
      <h2>9. Full-Page Detail — Entity Profile</h2>
      <p class="principle">Job: Show complete entity detail as a full page. Back button. Clean fields. No sidebar clutter.</p>

      <div class="diagram">
        <div class="wf-row">
          <div class="wf-sidebar" data-wf-id="wf-prof-sidebar">
            <div class="brand">TERP Operator</div>
            <div class="nav-item">Clients</div>
            <div class="nav-item dim">Vendors</div>
            <div class="nav-item dim">Sales</div>
          </div>
          <div class="wf-main">
            <!-- Back button -->
            <div class="wf-back" data-wf-id="wf-prof-back">← Back to Clients</div>

            <!-- Avatar + name -->
            <div style="display:flex;align-items:center;gap:14px;margin-bottom:16px;">
              <div class="wf-avatar" data-wf-id="wf-prof-avatar"></div>
              <div>
                <div style="font-size:var(--fs-17);font-weight:var(--fw-480);">Maria Gonzalez</div>
                <div style="font-size:var(--fs-13);color:var(--text-muted);">Procurement, Acme Corp</div>
              </div>
            </div>

            <!-- Tabs -->
            <div class="wf-tabs" data-wf-id="wf-prof-tabs">
              <span class="wf-tab active">Overview</span>
              <span class="wf-tab">Activity</span>
              <span class="wf-tab">Documents</span>
            </div>

            <!-- Field cards -->
            <div class="wf-card" data-wf-id="wf-prof-details">
              <table style="width:100%;font-size:var(--fs-14);">
                <tr><td style="color:var(--text-muted);padding:6px 12px 6px 0;width:100px;">Email</td><td style="padding:6px 0;">maria@acme.com</td></tr>
                <tr><td style="color:var(--text-muted);padding:6px 12px 6px 0;">Phone</td><td style="padding:6px 0;">555-123-4567</td></tr>
                <tr><td style="color:var(--text-muted);padding:6px 12px 6px 0;">Company</td><td style="padding:6px 0;">Acme Corporation</td></tr>
                <tr><td style="color:var(--text-muted);padding:6px 12px 6px 0;">Role</td><td style="padding:6px 0;">Procurement Manager</td></tr>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>WHAT</th><th>PATTERN</th></tr>
          <tr><td>Navigation</td><td>← Back button. No breadcrumbs. Clean return to list view.</td></tr>
          <tr><td>Avatar</td><td>Circle. Color-derived background. First initial or photo.</td></tr>
          <tr><td>Tabs</td><td>Overview / Activity / Documents. Pill-style. Simple.</td></tr>
          <tr><td>Fields</td><td>Label:value pairs in a clean card. No form chrome. Read-only.</td></tr>
        </table>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
         10. ERROR STATES & RECOVERY
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-errors">
      <h2>10. Error States &amp; Recovery</h2>
      <p class="principle">Job: Handle failures contextually. No modals. No heavy error banners.</p>

      <div class="diagram">
        <div class="wf-col gap-16">
          <!-- Pattern 1: Inline cell error -->
          <div class="wf-card">
            <div class="wf-label mb-12">Inline Cell Error</div>
            <div class="wf-table">
              <table class="wf-table-inner">
                <tr><th class="wf-th">Vendor</th><th class="wf-th">Status</th><th class="wf-th">Total</th></tr>
                <tr>
                  <td class="wf-td">Acme Corp</td>
                  <td class="wf-td">
                    <span class="wf-err-cell" data-wf-id="wf-err-cell-inline">
                      <b>⚠</b> Network error &nbsp;
                      <span style="color:var(--blue);text-decoration:underline;cursor:pointer;" data-wf-id="wf-err-retry">Retry</span>
                    </span>
                  </td>
                  <td class="wf-td">$12,400</td>
                </tr>
                <tr><td class="wf-td">Beta Inc</td><td class="wf-td"><span class="wf-tag green">Posted</span></td><td class="wf-td">$8,200</td></tr>
              </table>
            </div>
          </div>

          <!-- Pattern 2: Bulk action partial failure -->
          <div class="wf-card">
            <div class="wf-label mb-12">Bulk Action — Partial Failure</div>
            <div class="wf-bulkbar" data-wf-id="wf-err-bulkbar" style="background:var(--dark);">
              <span data-wf-id="wf-err-bulk-text">2 confirmed · <span style="color:#f87171;">1 failed</span></span>
              <span class="wf-btn sm" style="background:rgba(255,255,255,0.12);border:none;color:#fff;" data-wf-id="wf-err-bulk-view">View</span>
            </div>
          </div>

          <!-- Pattern 3: Empty state -->
          <div class="wf-card">
            <div class="wf-label mb-12">Empty State</div>
            <div class="wf-empty" data-wf-id="wf-err-empty">
              <p>No purchase orders yet</p>
              <span class="wf-btn primary" data-wf-id="wf-err-empty-cta">Create your first PO</span>
            </div>
          </div>
        </div>
      </div>

      <div class="specs">
        <table>
          <tr><th>PATTERN</th><th>WHERE</th><th>BEHAVIOR</th></tr>
          <tr><td>Inline cell error</td><td>Single cell mutation fails</td><td>Red left border. Error text + Retry link. Cell stays editable.</td></tr>
          <tr><td>Bulk failure</td><td>Bulk action partially succeeds</td><td>Dark bar shows success + failure counts. "View" to see failed rows.</td></tr>
          <tr><td>Empty state</td><td>No data in table</td><td>Centered message + CTA button. No illustration clutter.</td></tr>
          <tr><td>No modal</td><td>—</td><td>❌ Mercury never uses modal error dialogs.</td></tr>
          <tr><td>No banner</td><td>—</td><td>❌ Mercury has no persistent error banner component.</td></tr>
        </table>
      </div>
    </section>

  </div><!-- /page -->
</body>
</html>
