                </tr>
                <tr data-wf-id="wf-sel-row-checked-2">
                  <td class="wf-td"><span class="wf-cb checked"></span></td>
                  <td class="wf-td">Gamma Ltd</td>
                  <td class="wf-td"><span class="wf-tag green">Confirmed ▾</span></td>
