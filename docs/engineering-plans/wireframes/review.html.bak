    <!-- ═══════════════════════════════════════════════════════════════
         4. GRID VIEW — DETAIL SLIDEOVER
         ═══════════════════════════════════════════════════════════════ -->
    <section class="wireframe" id="wf-slideover">
      <h2>4. Grid View — Detail Slideover</h2>
      <p class="principle">Job: Show PO details on row click. Table compresses. No modal. No full navigation.</p>

      <div class="diagram">
        <div class="wf-row">
          <div class="wf-sidebar" data-wf-id="wf-so-sidebar">
            <div class="brand">TERP Operator</div>
            <div class="nav-item active">Purchase Orders</div>
            <div class="nav-item dim">Sales</div>
          </div>
          <div class="wf-main">
