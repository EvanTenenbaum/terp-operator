{
  "name": "terp-agro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client \"tsx watch src/server/index.ts\" \"vite --host 0.0.0.0\"",
    "server:dev": "tsx watch src/server/index.ts",
    "client:dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && tsup src/server/index.ts --format esm --platform node --out-dir dist/server",
    "start": "NODE_ENV=production node dist/server/index.js",
    "db:migrate": "tsx src/server/migrate.ts",
    "db:seed": "tsx src/server/seed.ts",
    "test:e2e": "playwright test",
    "audit:parity": "node scripts/check-backend-frontend-parity.mjs",
    "audit:product-roadmap": "node scripts/check-product-roadmap.mjs",
    "audit:self": "pnpm typecheck && pnpm audit:parity && pnpm audit:product-roadmap && pnpm build"
  },
  "dependencies": {
    "@ag-grid-community/client-side-row-model": "^32.3.3",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "ag-grid-community": "^32.3.3",
    "ag-grid-enterprise": "^32.3.3",
    "ag-grid-react": "^32.3.3",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.468.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "superjson": "^2.2.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.8",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
