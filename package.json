{
  "name": "terp-operator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "scripts": {
    "agent:doctor": "bash scripts/terp-operator-doctor.sh",
    "dev": "concurrently -k -n server,client \"tsx watch src/server/index.ts\" \"vite --host 0.0.0.0\"",
    "dev:e2e": "concurrently -k -n server,client \"tsx src/server/index.ts\" \"vite --host 0.0.0.0\"",
    "server:dev": "tsx watch src/server/index.ts",
    "client:dev": "vite --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build && tsup src/server/index.ts src/server/migrate.ts src/server/seed.ts --format esm --platform node --out-dir dist/server",
    "start": "NODE_ENV=production node dist/server/index.js",
    "db:migrate": "tsx src/server/migrate.ts",
    "db:seed": "tsx src/server/seed.ts",
    "db:seed:realistic": "DEMO_SEED_SCENARIO=realistic_100d tsx src/server/seed.ts",
    "db:migrate:prod": "node dist/server/migrate.js",
    "db:seed:prod": "node dist/server/seed.js",
    "db:seed:realistic:prod": "DEMO_SEED_SCENARIO=realistic_100d node dist/server/seed.js",
    "start:staging": "NODE_ENV=production pnpm db:migrate:prod && ALLOW_DEMO_SEED=true DEMO_SEED_SCENARIO=${DEMO_SEED_SCENARIO:-realistic_100d} pnpm db:seed:prod && (DATABASE_SSL=${DATABASE_SSL:-false} pnpm audit:realistic-demo || echo '[start:staging] audit:realistic-demo FAILED — continuing boot so server is reachable. See logs above for failed assertions; tracked at #121.') && NODE_ENV=production node dist/server/index.js",
    "staging:reset": "bash scripts/reset-staging-data.sh",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "audit:parity": "node scripts/check-backend-frontend-parity.mjs",
    "audit:product-roadmap": "node scripts/check-product-roadmap.mjs",
    "audit:realistic-demo": "node scripts/audit-realistic-demo-data.mjs",
    "audit:self": "pnpm typecheck && pnpm audit:parity && pnpm audit:product-roadmap && pnpm build",
    "docs:inventory": "tsx scripts/extract-component-inventory.ts",
    "cron:credit-engine-nightly": "tsx scripts/credit-engine-nightly-cron.ts",
    "cron:balance-reconciliation": "tsx scripts/customer-balance-reconciliation-cron.ts"
  },
  "dependencies": {
    "@ag-grid-community/client-side-row-model": "^32.3.3",
    "@tanstack/react-query": "^4.36.1",
    "@trpc/client": "^10.45.2",
    "@trpc/react-query": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "ag-grid-community": "^32.3.3",
    "ag-grid-enterprise": "^32.3.3",
    "ag-grid-react": "^32.3.3",
    "agentation": "^3.0.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "file-type": "^22.0.1",
    "helmet": "^8.0.0",
    "immer": "^10.1.1",
    "lru-cache": "^11.3.6",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.2",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "superjson": "^2.2.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.8",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
